# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@your-neon-host/la-brea-madre

# ─── Auth0 ────────────────────────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret
SESSION_SECRET=a_long_random_string_at_least_32_chars

# ─── App ──────────────────────────────────────────────────────────────────────
APP_DOMAIN=https://your-app-domain.com
PORT=5000
NODE_ENV=development

# Admin access (comma-separated emails)
ADMIN_EMAILS=you@example.com

# ─── LA Open Data (optional but recommended) ──────────────────────────────────
# Register at https://data.lacity.org/ for higher rate limits
SOCRATA_APP_TOKEN=

# ─── Dev ──────────────────────────────────────────────────────────────────────
# Set to "true" to enable /api/dev-login bypass (never in production)
ENABLE_DEV_LOGIN=false
